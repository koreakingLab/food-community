{"ast":null,"code":"import{useState,useEffect}from'react';export default function useCachedFetch(url){const[data,setData]=useState(()=>{const cached=sessionStorage.getItem(url);return cached?JSON.parse(cached):null;});const[loading,setLoading]=useState(!data);useEffect(()=>{fetch(url).then(res=>res.json()).then(json=>{setData(json);setLoading(false);sessionStorage.setItem(url,JSON.stringify(json));}).catch(()=>setLoading(false));},[url]);return{data,loading};}","map":{"version":3,"names":["useState","useEffect","useCachedFetch","url","data","setData","cached","sessionStorage","getItem","JSON","parse","loading","setLoading","fetch","then","res","json","setItem","stringify","catch"],"sources":["D:/food-community/client/src/hooks/useCachedFetch.js"],"sourcesContent":["import { useState, useEffect } from 'react';\r\n\r\nexport default function useCachedFetch(url) {\r\n  const [data, setData] = useState(() => {\r\n    const cached = sessionStorage.getItem(url);\r\n    return cached ? JSON.parse(cached) : null;\r\n  });\r\n  const [loading, setLoading] = useState(!data);\r\n\r\n  useEffect(() => {\r\n    fetch(url)\r\n      .then(res => res.json())\r\n      .then(json => {\r\n        setData(json);\r\n        setLoading(false);\r\n        sessionStorage.setItem(url, JSON.stringify(json));\r\n      })\r\n      .catch(() => setLoading(false));\r\n  }, [url]);\r\n\r\n  return { data, loading };\r\n}"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,KAAQ,OAAO,CAE3C,cAAe,SAAS,CAAAC,cAAcA,CAACC,GAAG,CAAE,CAC1C,KAAM,CAACC,IAAI,CAAEC,OAAO,CAAC,CAAGL,QAAQ,CAAC,IAAM,CACrC,KAAM,CAAAM,MAAM,CAAGC,cAAc,CAACC,OAAO,CAACL,GAAG,CAAC,CAC1C,MAAO,CAAAG,MAAM,CAAGG,IAAI,CAACC,KAAK,CAACJ,MAAM,CAAC,CAAG,IAAI,CAC3C,CAAC,CAAC,CACF,KAAM,CAACK,OAAO,CAAEC,UAAU,CAAC,CAAGZ,QAAQ,CAAC,CAACI,IAAI,CAAC,CAE7CH,SAAS,CAAC,IAAM,CACdY,KAAK,CAACV,GAAG,CAAC,CACPW,IAAI,CAACC,GAAG,EAAIA,GAAG,CAACC,IAAI,CAAC,CAAC,CAAC,CACvBF,IAAI,CAACE,IAAI,EAAI,CACZX,OAAO,CAACW,IAAI,CAAC,CACbJ,UAAU,CAAC,KAAK,CAAC,CACjBL,cAAc,CAACU,OAAO,CAACd